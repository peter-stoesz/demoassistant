{
  "name": "demo-assistant",
  "productName": "Demo Assistant",
  "version": "2.0.0",
  "description": "Screen overlay toolkit for live demos — sonar blips, selection boxes, smart paste, spotlight, freeze frame, annotations, zoom lens, and cue cards.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --mac --win",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "pack": "electron-builder --dir",
    "postinstall": "node scripts/install-onnx-shim.js"
  },
  "keywords": [
    "presentation",
    "demo",
    "overlay",
    "electron"
  ],
  "author": "Demo Assistant Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "papaparse": "^5.5.3"
  },
  "optionalDependencies": {
    "@jitsi/robotjs": "^0.6.21",
    "@xenova/transformers": "^2.17.0"
  }
}
